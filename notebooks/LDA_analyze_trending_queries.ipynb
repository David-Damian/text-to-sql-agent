   "source": [
    "n_topics = 5\n",
    "topic_names = {}\n",
    "# Configuración corregida para el nuevo SDK (google-genai)\n",
    "safe_config = types.GenerateContentConfig(\n",
    "    max_output_tokens=60,\n",
    "    safety_settings=[\n",
    "        types.SafetySetting(\n",
    "            category=\"HARM_CATEGORY_HATE_SPEECH\", \n",
    "            threshold=\"BLOCK_NONE\"\n",
    "        ),\n",
    "        types.SafetySetting(\n",
    "            category=\"HARM_CATEGORY_HARASSMENT\", \n",
    "            threshold=\"BLOCK_NONE\"\n",
    "        ),\n",
    "        types.SafetySetting(\n",
    "            category=\"HARM_CATEGORY_DANGEROUS_CONTENT\", \n",
    "            threshold=\"BLOCK_NONE\"\n",
    "        ),\n",
    "        types.SafetySetting(\n",
    "            category=\"HARM_CATEGORY_SEXUALLY_EXPLICIT\", \n",
    "            threshold=\"BLOCK_NONE\"\n",
    "        ),\n",
    "    ]\n",
    ")\n",
    "\n",
    "for t in range(n_topics):\n",
    "    print(f'Procesando tema {t}...')\n",
    "    qs = (\n",
    "        df_docs[df_docs[\"top_topic\"] == t]\n",
    "        .nlargest(10, \"top_topic_conf\")\n",
    "        [\"text_raw\"]\n",
    "        .tolist()\n",
    "    )\n",
    "    if not qs:\n",
    "        topic_names[t] = f\"Tema {t}\"\n",
    "        continue\n",
    "    # 1. Prompt limpio (sin espacios raros a la izquierda)\n",
    "    # textwrap.dedent -> Esta función detecta automáticamente la indentación común de todas las líneas y la elimina.\n",
    "    prompt = textwrap.dedent(f\"\"\"Estas son preguntas de usuarios a un asistente conversacional de IA \n",
    "                para consultas técnicas, solicitudes de código y soporte general. \n",
    "                Dame un titulo descriptivo en español.\n",
    "                REGLA: El título debe tener entre 2 y 4 palabras, incluyendo el lenguaje de programación de los que se habla \n",
    "                si es que aplica.\n",
    "                EJEMPLOS: \"Depuración de código Python\", \"Consultas de SQL\", \"Soporte de API\".\n",
    "                PREGUNTAS:\n",
    "                {chr(10).join([f'- {q[:160]}' for q in qs])}\n",
    "                RESPUESTA (SOLO EL TÍTULO):\n",
    "                \"\"\"\n",
    "    )\n",
    "\n",
    "   # resp = client.chat.completions.create(\n",
    "   #     model=\"gpt-4o-mini\",\n",
    "   #     messages=[{\"role\": \"user\", \"content\": prompt}],\n",
    "   #     max_tokens=30\n",
    "   # )\n",
    "    resp = client.models.generate_content(\n",
    "    model=MODEL_ID,\n",
    "    contents=prompt,\n",
    "    # Relajar los Filtros de Seguridad de Gemini\n",
    "    config=safe_config\n",
    "    )\n",
    "    # Para openai\n",
    "    #topic_names[t] = resp.choices[0].message.content.strip().strip('\"')\n",
    "    # Para Gemini\n",
    "    if resp.candidates[0].finish_reason == \"SAFETY\":\n",
    "        print(f\"⚠️ El Tema {t} fue bloqueado por seguridad.\")\n",
    "        print(f\"Calificaciones: {resp.candidates[0].safety_ratings}\")\n",
    "    topic_names[t] = (resp.text or \"\").strip().strip('\"') or \"Unknown Topic\"\n",
    "    print(f\"Topic {t}: {topic_names[t]}\")"
   ]
  },
