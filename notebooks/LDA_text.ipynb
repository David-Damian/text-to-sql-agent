          "text": [
            "Docs (clean, non-empty): 3885\n",
            "Top tokens after preprocessing: [('mejor', 245), ('pued', 240), ('cre', 221), ('list', 204), ('program', 197), ('diferent', 179), ('deb', 177), ('algun', 164), ('funcion', 152), ('pas', 142), ('ayud', 137), ('dec', 136), ('explic', 133), ('cad', 133), ('python', 131), ('palabr', 130), ('form', 127), ('sistem', 124), ('cuent', 123), ('siguient', 123)]\n"
          ]
        }
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "\n",
        "# -----------------------\n",
        "# 4) Bag-of-words\n",
        "# -----------------------\n",
        "vectorizer = CountVectorizer(max_df=0.9, min_df=2, ngram_range=(1, 2))\n",
        "X = vectorizer.fit_transform(docs_clean)\n",
        "vocab = np.array(vectorizer.get_feature_names_out())\n",
        "print(\"Vocab size:\", len(vocab))\n",
        "\n"
      ],
      "metadata": {
        "id": "X3T7PK31QtPX",
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "outputId": "d0e49de4-41b6-4c16-e6b8-21f7ba858547"
      },
      "execution_count": null,
      "outputs": [
        {
          "output_type": "stream",
