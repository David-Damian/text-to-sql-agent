            "Vocab size: 5129\n"
          ]
        }
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "\n",
        "# -----------------------\n",
        "# 5) Fit LDA\n",
        "# -----------------------\n",
        "n_topics = 5\n",
        "lda = LatentDirichletAllocation(\n",
        "    n_components=n_topics,\n",
        "    learning_method=\"batch\",\n",
        "    random_state=RANDOM_SEED,\n",
        "    max_iter=25\n",
        ")\n",
        "lda.fit(X)\n"
      ],
